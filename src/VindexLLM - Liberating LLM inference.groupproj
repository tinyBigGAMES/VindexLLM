<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{0546100D-1B69-4D65-A811-06847C679BB5}</ProjectGuid>
    </PropertyGroup>
    <ItemGroup>
        <Projects Include="..\testbed\VdxTestbed.dproj">
            <Dependencies/>
        </Projects>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Default.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Default.Personality/>
        </BorlandProject>
    </ProjectExtensions>
    <Target Name="VdxTestbed">
        <MSBuild Projects="..\testbed\VdxTestbed.dproj"/>
    </Target>
    <Target Name="VdxTestbed:Clean">
        <MSBuild Projects="..\testbed\VdxTestbed.dproj" Targets="Clean"/>
    </Target>
    <Target Name="VdxTestbed:Make">
        <MSBuild Projects="..\testbed\VdxTestbed.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="VdxTestbed"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="VdxTestbed:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="VdxTestbed:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
</Project>
