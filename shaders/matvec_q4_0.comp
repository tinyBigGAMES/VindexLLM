#version 450
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require

// MatVec Q4_0: Q4_0 weight matrix x F32 vector.
//
// Q4_0 block format (18 bytes, 32 elements):
//   bytes 0-1:   F16 scale factor d
//   bytes 2-17:  16 bytes of packed nibbles qs[0..15]
//
// Packing:
//   qs[j] & 0x0F        -> element j        (j in 0..15)
//   (qs[j] >> 4) & 0x0F -> element j + 16   (j in 0..15)
//
// Dequant: value = (int(nibble) - 8) * scale
//
// Dispatch: (out_dim, 1, 1) — one workgroup per output row.
//
// Bindings:
//   0 = weight data (uint8_t[], raw Q4_0 blocks, row-major)
//   1 = input vector (float[], in_dim elements)
//   2 = output vector (float[], out_dim elements)

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint in_dim;
    uint out_dim;
} pc;

layout(std430, binding = 0) readonly buffer WeightBuf {
    uint8_t weight_bytes[];
};

layout(std430, binding = 1) readonly buffer InputBuf {
    float input_vec[];
};

layout(std430, binding = 2) writeonly buffer OutputBuf {
    float output_vec[];
};

shared float partial[64];

void main() {
    uint row = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationID.x;

    if (row >= pc.out_dim)
        return;

    uint blocks_per_row = pc.in_dim >> 5;
    uint row_byte_off   = row * blocks_per_row * 18u;

    float acc = 0.0;

    for (uint elem = tid; elem < pc.in_dim; elem += 64) {
        uint blk_idx  = elem >> 5;
        uint in_blk   = elem & 31u;
        uint byte_idx = in_blk & 15u;
        uint is_high  = in_blk >> 4;
        uint blk_off  = row_byte_off + blk_idx * 18u;

        uint s_lo     = uint(weight_bytes[blk_off]) & 0xFFu;
        uint s_hi     = uint(weight_bytes[blk_off + 1u]) & 0xFFu;
        float scale   = unpackHalf2x16(s_lo | (s_hi << 8)).x;

        uint qs_off   = blk_off + 2u + byte_idx;
        uint raw      = uint(weight_bytes[qs_off]) & 0xFFu;
        uint nibble   = (raw >> (is_high * 4u)) & 0x0Fu;
        float qval    = float(int(nibble) - 8);
        acc += qval * scale * input_vec[elem];
    }

    partial[tid] = acc;
    barrier();

    for (uint stride = 32; stride > 0; stride >>= 1) {
        if (tid < stride) {
            partial[tid] += partial[tid + stride];
        }
        barrier();
    }

    if (tid == 0) {
        output_vec[row] = partial[0];
    }
}
