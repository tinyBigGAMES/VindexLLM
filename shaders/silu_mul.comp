#version 450

// SiLU-Mul: compute hidden = SiLU(gate) * up, in-place on gate buffer.
// SiLU(x) = x / (1 + exp(-x))
//
// Bindings:
//   0 = gate (float[], read-write, overwritten with result)
//   1 = up   (float[], read-only)
//
// Push constants:
//   count = number of elements

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint count;
} pc;

layout(std430, binding = 0) buffer GateBuf {
    float gate_data[];
};

layout(std430, binding = 1) readonly buffer UpBuf {
    float up_data[];
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= pc.count)
        return;

    float g = gate_data[idx];
    float silu_g = g / (1.0 + exp(-g));
    gate_data[idx] = silu_g * up_data[idx];
}
