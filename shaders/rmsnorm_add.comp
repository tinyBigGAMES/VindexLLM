#version 450

// Fused RMSNorm+Add: reads input, normalizes, adds to accumulator.
// Eliminates the separate RMSNorm (in-place) + VecAdd pattern.
// Single workgroup dispatch (1,1,1). All work done in shared memory.
//
// Formula: accum[i] += (input[i] / rms) * weight[i]
//          rms = sqrt(sum(input[j]^2) / dim + eps)
//
// Bindings:
//   0 = input vector  (float[], HiddenDim elements, read-only)
//   1 = weight vector (float[], HiddenDim elements, read-only)
//   2 = accumulator   (float[], HiddenDim elements, read-write)
//
// Push constants:
//   hidden_dim = number of elements
//   eps        = epsilon for numerical stability (1e-6)

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint  hidden_dim;
    float eps;
} pc;

layout(std430, binding = 0) readonly buffer InputBuf {
    float input_vec[];
};

layout(std430, binding = 1) readonly buffer WeightBuf {
    float weight[];
};

layout(std430, binding = 2) buffer AccumBuf {
    float accum[];
};

// Shared memory for parallel reduction
shared float partial_sums[256];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint dim = pc.hidden_dim;

    // Phase 1: Each thread accumulates sum-of-squares for its elements
    float sum_sq = 0.0;
    for (uint i = tid; i < dim; i += 256) {
        float val = input_vec[i];
        sum_sq += val * val;
    }
    partial_sums[tid] = sum_sq;

    barrier();

    // Parallel reduction in shared memory
    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride) {
            partial_sums[tid] += partial_sums[tid + stride];
        }
        barrier();
    }

    // Thread 0 computes the final RMS value and stores in shared[0]
    if (tid == 0) {
        partial_sums[0] = 1.0 / sqrt(partial_sums[0] / float(dim) + pc.eps);
    }

    barrier();

    // Phase 2: Each thread normalizes input and adds to accumulator
    float inv_rms = partial_sums[0];
    for (uint i = tid; i < dim; i += 256) {
        accum[i] += input_vec[i] * inv_rms * weight[i];
    }
}
