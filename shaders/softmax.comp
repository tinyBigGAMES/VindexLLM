#version 450

// Softmax: normalize attention scores in-place.
// Single workgroup dispatch. Uses shared memory for parallel reduction.
//
// Three phases:
//   1. Find max value (for numerical stability)
//   2. Compute exp(score - max) in-place and sum
//   3. Divide by sum
//
// Bindings:
//   0 = scores (float[], seq_len elements, read/write in-place)
//
// Push constants:
//   seq_len = number of elements

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint seq_len;
} pc;

layout(std430, binding = 0) buffer ScoresBuf {
    float scores[];
};

shared float shared_data[256];

void main() {
    uint tid = gl_LocalInvocationID.x;

    // Phase 1: Find max (parallel reduction)
    float local_max = -1.0e30;
    for (uint i = tid; i < pc.seq_len; i += 256) {
        local_max = max(local_max, scores[i]);
    }
    shared_data[tid] = local_max;
    barrier();

    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride) {
            shared_data[tid] = max(shared_data[tid], shared_data[tid + stride]);
        }
        barrier();
    }
    float max_val = shared_data[0];
    barrier();

    // Phase 2: Compute exp(x - max) in-place and sum
    float local_sum = 0.0;
    for (uint i = tid; i < pc.seq_len; i += 256) {
        float e = exp(scores[i] - max_val);
        scores[i] = e;
        local_sum += e;
    }
    shared_data[tid] = local_sum;
    barrier();

    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride) {
            shared_data[tid] += shared_data[tid + stride];
        }
        barrier();
    }
    float total_sum = shared_data[0];
    barrier();

    // Phase 3: Normalize
    float inv_sum = 1.0 / total_sum;
    for (uint i = tid; i < pc.seq_len; i += 256) {
        scores[i] = scores[i] * inv_sum;
    }
}