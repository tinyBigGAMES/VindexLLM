#version 450
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require

// MatVec Q8_0: Q8_0 weight matrix x F32 vector.
//
// Q8_0 block format (34 bytes, 32 elements):
//   bytes 0-1:  f16 scale factor
//   bytes 2-33: 32 int8 quantized values
//   dequant: value = int8_val * scale
//
// Block scales are cooperatively loaded into shared memory (Phase 1),
// then reused during the per-element dot product (Phase 2). The shared
// array size is set via specialization constant at pipeline creation,
// so it always matches the model's actual blocks_per_row — no overflow.
//
// Dispatch: one workgroup per output row -> (out_dim, 1, 1) workgroups.
//
// Bindings:
//   0 = weight data (int8_t[], raw Q8_0 blocks, row-major)
//   1 = input vector (float[], in_dim elements)
//   2 = output vector (float[], out_dim elements)
//
// Push constants:
//   in_dim  = input dimension (must be multiple of 32)
//   out_dim = output dimension

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
// Specialization constant: set at pipeline creation to actual blocks_per_row
layout(constant_id = 0) const uint MAX_BLOCKS = 256;

layout(push_constant) uniform PushConstants {
    uint in_dim;
    uint out_dim;
} pc;

layout(std430, binding = 0) readonly buffer WeightBuf {
    int8_t weight_bytes[];
};

layout(std430, binding = 1) readonly buffer InputBuf {
    float input_vec[];
};

layout(std430, binding = 2) writeonly buffer OutputBuf {
    float output_vec[];
};

// Scale cache + reduction scratch
shared float blk_scales[MAX_BLOCKS];
shared float partial[256];
void main() {
    uint row = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationID.x;

    if (row >= pc.out_dim)
        return;

    uint blocks_per_row = pc.in_dim >> 5;        // in_dim / 32
    uint row_byte_off   = row * blocks_per_row * 34u;

    // === Phase 1: Cooperatively load all block scales into shared memory ===
    for (uint b = tid; b < blocks_per_row; b += 256) {
        uint off = row_byte_off + b * 34u;
        uint lo  = uint(weight_bytes[off]) & 0xFFu;
        uint hi  = uint(weight_bytes[off + 1u]) & 0xFFu;
        blk_scales[b] = unpackHalf2x16(lo | (hi << 8)).x;
    }
    barrier();

    // === Phase 2: Per-element dot product with cached scales ===
    float acc = 0.0;

    for (uint elem = tid; elem < pc.in_dim; elem += 256) {
        uint blk_idx = elem >> 5;
        float qval   = float(weight_bytes[row_byte_off + blk_idx * 34u + 2u + (elem & 31u)]);
        acc += qval * blk_scales[blk_idx] * input_vec[elem];
    }

    partial[tid] = acc;
    barrier();

    // Parallel reduction in shared memory
    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride) {
            partial[tid] += partial[tid + stride];
        }
        barrier();
    }

    if (tid == 0) {
        output_vec[row] = partial[0];
    }
}