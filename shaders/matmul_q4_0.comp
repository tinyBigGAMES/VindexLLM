#version 450
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require

// MatMul Q4_0 (Tiled): Q4_0 weight matrix x F32 input matrix -> F32 output matrix.
//
// Dispatch: 2D — (out_dim, num_tokens, 1)

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint in_dim;
    uint out_dim;
    uint num_tokens;
} pc;

layout(std430, binding = 0) readonly buffer WeightBuf { uint8_t weight_bytes[]; };
layout(std430, binding = 1) readonly buffer InputBuf  { float input_mat[]; };
layout(std430, binding = 2) writeonly buffer OutputBuf { float output_mat[]; };

shared float partial[64];

void main() {
    uint row = gl_WorkGroupID.x;
    uint tok = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;

    if (row >= pc.out_dim || tok >= pc.num_tokens)
        return;

    uint blocks_per_row = pc.in_dim >> 5;
    uint row_byte_off   = row * blocks_per_row * 18u;
    uint input_base     = tok * pc.in_dim;

    float acc = 0.0;

    for (uint elem = tid; elem < pc.in_dim; elem += 64) {
        uint blk_idx  = elem >> 5;
        uint in_blk   = elem & 31u;
        uint byte_idx = in_blk & 15u;
        uint is_high  = in_blk >> 4;
        uint blk_off  = row_byte_off + blk_idx * 18u;

        uint s_lo     = uint(weight_bytes[blk_off]) & 0xFFu;
        uint s_hi     = uint(weight_bytes[blk_off + 1u]) & 0xFFu;
        float scale   = unpackHalf2x16(s_lo | (s_hi << 8)).x;

        uint qs_off   = blk_off + 2u + byte_idx;
        uint raw      = uint(weight_bytes[qs_off]) & 0xFFu;
        uint nibble   = (raw >> (is_high * 4u)) & 0x0Fu;
        float qval    = float(int(nibble) - 8);
        acc += qval * scale * input_mat[input_base + elem];
    }

    partial[tid] = acc;
    barrier();

    for (uint stride = 32; stride > 0; stride >>= 1) {
        if (tid < stride) {
            partial[tid] += partial[tid + stride];
        }
        barrier();
    }

    if (tid == 0) {
        output_mat[tok * pc.out_dim + row] = partial[0];
    }
}
